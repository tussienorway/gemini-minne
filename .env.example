# =============================================
# GEMINI-MINNE - Miljovariabler
# Kopier denne til .env og fyll inn verdiene
# =============================================

# --- LLM-BACKEND ---
# Velg hvilken AI-modell som brukes som standard
# Alternativer: gemini | openai | ollama | claude
LLM_BACKEND=gemini

# --- GEMINI (Google) ---
GEMINI_API_KEY=din-gemini-api-nokkel-her
GEMINI_MODEL=gemini-2.0-flash
# Tilgjengelige modeller: gemini-2.0-flash, gemini-1.5-pro, gemini-2.5-flash

# --- OPENAI (GPT) ---
OPENAI_API_KEY=din-openai-api-nokkel-her
OPENAI_MODEL=gpt-4o-mini
# Tilgjengelige modeller: gpt-4o, gpt-4o-mini, gpt-4-turbo

# --- OLLAMA (Lokal - ingen API-nokkel) ---
OLLAMA_MODEL=llama3
# Tilgjengelige modeller: llama3, mistral, phi3, gemma2
# Krav: Ollama maa kjore lokalt (https://ollama.ai)

# --- ANTHROPIC (Claude) ---
ANTHROPIC_API_KEY=din-claude-api-nokkel-her
CLAUDE_MODEL=claude-3-5-haiku-20241022
# Tilgjengelige modeller: claude-3-5-sonnet, claude-3-5-haiku, claude-opus-4

# --- GITHUB (Langtidsminne i skyen) ---
GITHUB_TOKEN=din-github-personal-access-token
GITHUB_REPO=tussienorway/gemini-minne
GITHUB_BRANCH=main

# --- MINNE-INNSTILLINGER ---
MEMORY_DIR=./minne
SHORT_TERM_SIZE=20
